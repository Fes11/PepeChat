{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PepeChat",
  "version": "0.1.0",
  "identifier": "fun.pepechat.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "PepeChat",
        "width": 1200,
        "height": 800,
        "minWidth": 1000,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "maximized": false,
        "transparent": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlDNzY5MjNDRUVBMUY4MzgKUldRNCtLSHVQSkoybk02eGFRVEYzMnlRMHJvSGZvaG1MTUcyZHQ4cmJ3YjN5ZGFYRU5UekZIUTEK",
      "endpoints": [
        "https://github.com/Fes11/PepeChat/releases/latest/download/latest.json"
      ],
      "windows": { "installMode": "passive" }
    }
  }
}
